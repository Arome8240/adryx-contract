# Private key of the wallet sending the transactions
PRIVATE_KEY=your-hex-private-key-here

# Stacks network: mainnet | testnet
STACKS_NETWORK=mainnet

# Optional: override the default Hiro API URL
# STACKS_API_URL=https://api.hiro.so

# Address that deployed stackads-token
CONTRACT_ADDRESS=SP25H46Z9YCAB1TW93YG42WM0SREG9SC5EZB977TJ

# Recipient of each transfer
RECIPIENT_ADDRESS=SP1EQNTKNRGME36P9EEXZCFFNCYBA50VN51676JB

# Number of transactions to send (default: 100)
TX_COUNT=100

# Fee per transaction in micro-STX (default: 6000 = 0.006 STX)
FEE=6000

# Delay between broadcasts in ms (default: 5000)
DELAY_MS=5000

# How long to pause when a rate limit is hit in ms (default: 30000).
PAUSE_ON_RATE_LIMIT_MS=30000
